<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="revo2_system">

  <xacro:arg name="prefix" default=""/>
  <xacro:arg name="ctrl_mode_param2_time_ms" default=""/>
  
  <!-- 属性定义 -->
  <xacro:property name="prefix" value="$(arg prefix)" />

  <!-- 导入 ros2_control 配置 -->
  <xacro:include filename="$(find revo2_ethercat_driver_ros2)/description/ros2_control/revo2_system.ros2_control.xacro"/>

  <!-- TODO simple definition -->
  <!-- 基础连杆 -->
  <link name="${prefix}revo2_base_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="1.0"/>
      <inertia ixx="0.001" ixy="0.0" ixz="0.0" iyy="0.001" iyz="0.0" izz="0.001"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.2 0.05"/>
      </geometry>
      <material name="base_material">
        <color rgba="0.8 0.8 0.8 1.0"/>
      </material>
    </visual>
    <collision>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.1 0.2 0.05"/>
      </geometry>
    </collision>
  </link>

  <!-- 手掌连杆 -->
  <link name="${prefix}revo2_palm_link">
    <inertial>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <mass value="0.5"/>
      <inertia ixx="0.0005" ixy="0.0" ixz="0.0" iyy="0.0005" iyz="0.0" izz="0.0005"/>
    </inertial>
    <visual>
      <origin xyz="0 0 0" rpy="0 0 0"/>
      <geometry>
        <box size="0.08 0.15 0.02"/>
      </geometry>
      <material name="palm_material">
        <color rgba="0.9 0.9 0.9 1.0"/>
      </material>
    </visual>
  </link>

  <!-- 基座到手掌的固定关节 -->
  <joint name="${prefix}base_to_palm_joint" type="fixed">
    <parent link="${prefix}revo2_base_link"/>
    <child link="${prefix}revo2_palm_link"/>
    <origin xyz="0 0 0.03" rpy="0 0 0"/>
  </joint>

  <!-- 手指关节和连杆宏定义 -->
  <xacro:macro name="finger_joint_link" params="name parent origin_xyz origin_rpy">
    <!-- 手指连杆 -->
    <link name="${prefix}${name}_link">
      <inertial>
        <origin xyz="0 0 0" rpy="0 0 0"/>
        <mass value="0.1"/>
        <inertia ixx="0.0001" ixy="0.0" ixz="0.0" iyy="0.0001" iyz="0.0" izz="0.0001"/>
      </inertial>
      <visual>
        <origin xyz="0 0 0.015" rpy="0 0 0"/>
        <geometry>
          <cylinder radius="0.01" length="0.03"/>
        </geometry>
        <material name="${name}_material">
          <color rgba="0.7 0.7 0.9 1.0"/>
        </material>
      </visual>
    </link>

    <!-- 手指关节 (revolute，可旋转) -->
    <joint name="${prefix}${name}_joint" type="revolute">
      <parent link="${prefix}${parent}_link"/>
      <child link="${prefix}${name}_link"/>
      <origin xyz="${origin_xyz}" rpy="${origin_rpy}"/>
      <axis xyz="0 0 1"/>
      <!-- 关节限制：对应 Revo2 位置范围 1-900 映射到弧度 -->
      <limit lower="0.001" upper="15.708" velocity="2.0" effort="10.0"/>
    </joint>
  </xacro:macro>

  <!-- 创建6个手指关节 -->
  <!-- 拇指尖部 -->
  <xacro:finger_joint_link name="thumb_flex" parent="revo2_palm" 
                          origin_xyz="0.03 0.05 0" origin_rpy="0 0 0"/>

  <!-- 拇指根部 -->  
  <xacro:finger_joint_link name="thumb_abduct" parent="revo2_palm"
                          origin_xyz="0.02 0.05 0" origin_rpy="0 0 0"/>

  <!-- 食指 -->
  <xacro:finger_joint_link name="index" parent="revo2_palm"
                          origin_xyz="0.01 0.07 0" origin_rpy="0 0 0"/>

  <!-- 中指 -->
  <xacro:finger_joint_link name="middle" parent="revo2_palm"
                          origin_xyz="0.0 0.075 0" origin_rpy="0 0 0"/>

  <!-- 无名指 -->
  <xacro:finger_joint_link name="ring" parent="revo2_palm"
                          origin_xyz="-0.01 0.07 0" origin_rpy="0 0 0"/>

  <!-- 小指 -->
  <xacro:finger_joint_link name="pinky" parent="revo2_palm"
                          origin_xyz="-0.02 0.06 0" origin_rpy="0 0 0"/>

  <!-- ros2_control 配置 -->
  <xacro:revo2_system_ros2_control 
    name="revo2_joints_system" 
    prefix="${prefix}"
    ctrl_mode_param2_time_ms="$(arg ctrl_mode_param2_time_ms)"
    />

</robot>
